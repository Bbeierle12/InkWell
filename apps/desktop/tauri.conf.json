{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/dev/tooling/cli/schema.json",
  "productName": "Inkwell",
  "version": "0.0.1",
  "identifier": "com.inkwell.app",
  "build": {
    "frontendDist": "../web/out"
  },
  "app": {
    "title": "Inkwell",
    "windows": [
      {
        "title": "Inkwell",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
