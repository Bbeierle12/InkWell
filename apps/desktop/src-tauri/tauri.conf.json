{
  "productName": "Inkwell",
  "version": "0.0.1",
  "identifier": "com.inkwell.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter @inkwell/web run dev --port 3004",
    "beforeBuildCommand": "pnpm --filter @inkwell/web run build",
    "devUrl": "http://localhost:3004",
    "frontendDist": "../../web/out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Inkwell",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["inkwell"],
        "mimeType": "application/x-inkwell",
        "description": "Inkwell Document",
        "role": "Editor"
      },
      {
        "ext": ["md"],
        "mimeType": "text/markdown",
        "description": "Markdown Document",
        "role": "Editor"
      }
    ],
    "category": "Productivity",
    "shortDescription": "AI-powered word processor",
    "longDescription": "Inkwell is an AI word processor with local inference, privacy-first design, and hybrid local/cloud AI."
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["inkwell"]
      }
    }
  }
}
