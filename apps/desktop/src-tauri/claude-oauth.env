# Claude OAuth settings for local desktop development.
# This file is loaded automatically by the desktop app at startup.
# Replace the client id value with your real OAuth app client id.

INKWELL_CLAUDE_OAUTH_ENABLED=false
INKWELL_CLAUDE_OAUTH_CLIENT_ID=replace-with-your-claude-client-id
INKWELL_CLAUDE_OAUTH_REDIRECT_URI=inkwell://auth/callback
INKWELL_CLAUDE_OAUTH_SCOPE=openid profile offline_access
INKWELL_CLAUDE_OAUTH_AUTH_URL=https://claude.ai/oauth/authorize
INKWELL_CLAUDE_OAUTH_TOKEN_URL=https://claude.ai/oauth/token
INKWELL_CLAUDE_OAUTH_API_BASE_URL=https://api.anthropic.com
